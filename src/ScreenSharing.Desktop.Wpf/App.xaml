<Application x:Class="ScreenSharing.Desktop.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ScreenSharing.Desktop.App"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:ScreenSharing.Desktop.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <conv:InvertBoolConverter x:Key="InvertBool" />
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility" />
            <conv:ViewModelToPageConverter x:Key="VmToPage" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
