<UserControl x:Class="ScreenSharing.Desktop.App.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ScreenSharing.Desktop.App.ViewModels"
             xmlns:rendering="clr-namespace:ScreenSharing.Desktop.App.Rendering"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=vm:RoomViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Outer 2-column layout. Column 0 holds the room (top bar +
         video area + footer); column 1 holds the stats sidebar which
         only takes space when IsStatsPanelOpen. The room shrinks
         automatically when the panel opens — no overlap. -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="16,8,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: room id chip on the left, Stats + Settings + Leave on the right. -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="14"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding ConnectionDotBrush}"
                                 VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding RoomId}"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <ui:Button Appearance="Transparent"
                                   Icon="{ui:SymbolIcon Symbol=Copy24}"
                                   ToolTip="Copy room ID"
                                   Click="OnCopyRoomIdClick"
                                   Padding="4" Margin="6,0,0,0" />
                    </StackPanel>
                </Border>

                <ui:Button Grid.Column="2"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=DataPie24}"
                           Command="{Binding ToggleStatsPanelCommand}"
                           ToolTip="Stream stats" />
                <ui:Button Grid.Column="3"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=Settings24}"
                           Command="{Binding ShowSettingsCommand}"
                           ToolTip="Settings"
                           Margin="8,0,0,0" />
                <ui:Button Grid.Column="4"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=SignOut24}"
                           Content="Leave"
                           Command="{Binding LeaveRoomCommand}"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- Video area: row 0 stretches (remote stream),
                 row 1 is Auto (self preview, only when sharing). -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        CornerRadius="8" ClipToBounds="True"
                        Background="Black">
                    <Grid>
                        <rendering:D3DImageVideoRenderer x:Name="RemoteRenderer"
                                                         Receiver="{Binding StreamReceiver}"
                                                         NominalFrameRate="{Binding RemoteNominalFrameRate}"
                                                         Visibility="{Binding HasRemoteVideo, Converter={StaticResource BoolToVisibility}}" />

                        <Grid Background="#80000000"
                              Visibility="{Binding IsRemotePaused, Converter={StaticResource BoolToVisibility}}"
                              IsHitTestVisible="False">
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="#CC1E1E1E"
                                    CornerRadius="16"
                                    Padding="20,10">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Pause24" FontSize="18" Foreground="White"
                                                   VerticalAlignment="Center" />
                                    <TextBlock Text="Paused" Foreground="White"
                                               FontWeight="SemiBold" FontSize="14"
                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Width="320" Height="180"
                        CornerRadius="8"
                        BorderThickness="2"
                        BorderBrush="#FFD13A3A"
                        Background="Black"
                        ClipToBounds="True"
                        Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <rendering:D3DImageVideoRenderer x:Name="SelfRenderer"
                                                         LocalPreviewSource="{Binding LocalPreviewSource}" />
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="6"
                                Background="#CCD13A3A"
                                CornerRadius="8"
                                Padding="6,2"
                                IsHitTestVisible="False">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="White"
                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="LIVE" Foreground="White"
                                           FontWeight="Bold" FontSize="9"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer: Share button + members strip. -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Symbol=Share24}"
                           Content="Share screen"
                           Command="{Binding ShareScreenCommand}"
                           Visibility="{Binding IsSharing, Converter={StaticResource InvertBoolToVisibility}}" />
                <ui:Button Grid.Column="0"
                           Appearance="Danger"
                           Icon="{ui:SymbolIcon Symbol=DismissCircle24}"
                           Content="Stop sharing"
                           Command="{Binding StopSharingCommand}"
                           Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibility}}" />

                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="16,0,0,0">
                    <ItemsControl ItemsSource="{Binding Peers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PeerViewModel}">
                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="20"
                                        Padding="6,4,12,4"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="White" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                                        <ui:SymbolIcon Symbol="Star24" Foreground="#FFD479" FontSize="13"
                                                       VerticalAlignment="Center" Margin="6,0,0,0"
                                                       ToolTip="Host"
                                                       Visibility="{Binding IsHost, Converter={StaticResource BoolToVisibility}}" />
                                        <Ellipse Width="8" Height="8" Fill="#FFD13A3A"
                                                 VerticalAlignment="Center" Margin="6,0,0,0"
                                                 ToolTip="Streaming"
                                                 Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisibility}}" />
                                        <TextBlock Text="(you)" Opacity="0.5" FontSize="11"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   Visibility="{Binding IsSelf, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Right-edge stats panel. Visible only when IsStatsPanelOpen.
             Width is fixed; the main column auto-shrinks to fit. -->
        <Border Grid.Column="1"
                Width="320"
                Margin="0,8,16,16"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsStatsPanelOpen, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="16,12,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Stream stats"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1"
                               Appearance="Transparent"
                               Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                               Command="{Binding CloseStatsPanelCommand}"
                               Padding="4"
                               ToolTip="Close" />
                </Grid>

                <ScrollViewer Grid.Row="1" Padding="12,0,12,12"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ui:Card Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="14" />
                                    <TextBlock Text="Outgoing (you)" FontWeight="SemiBold"
                                               Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding OutgoingStats}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11" Opacity="0.85" />
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" />
                                    <TextBlock Text="Incoming" FontWeight="SemiBold"
                                               Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding IncomingStats}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11" Opacity="0.85" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
