<UserControl x:Class="ScreenSharing.Desktop.Wpf.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ScreenSharing.Desktop.Wpf.ViewModels"
             xmlns:rendering="clr-namespace:ScreenSharing.Desktop.Wpf.Rendering"
             d:DataContext="{d:DesignInstance Type=vm:RoomViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Room" Opacity="0.6" FontSize="12" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding RoomId}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="{Binding CopyButtonText}" Click="OnCopyRoomIdClick"
                            Margin="8,0,0,0" VerticalAlignment="Center" Padding="12,4" />
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="Share"
                    Command="{Binding ShareScreenCommand}"
                    Visibility="{Binding IsSharing, Converter={StaticResource InvertBoolToVisibility}}"
                    Padding="16,6" />
            <Button Grid.Column="2" Content="Stop sharing"
                    Command="{Binding StopSharingCommand}"
                    Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibility}}"
                    Padding="16,6" Margin="8,0,0,0" />
            <Button Grid.Column="3" Content="Leave"
                    Command="{Binding LeaveRoomCommand}"
                    Padding="16,6" Margin="8,0,0,0" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderThickness="1" BorderBrush="#40808080" Background="#10000000">
                <Grid>
                    <!-- Renderer is always in the tree so HwndHost builds
                         its child window immediately and AttachReceiver
                         fires as soon as the VM exposes a StreamReceiver.
                         A Collapsed HwndHost defers BuildWindowCore and
                         you end up with zero subscribers to FrameArrived. -->
                    <rendering:D3DImageVideoRenderer Receiver="{Binding StreamReceiver}" />
                    <TextBlock Text="No incoming stream"
                               FontSize="14" Opacity="0.6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasRemoteStream, Converter={StaticResource InvertBoolToVisibility}}"
                               IsHitTestVisible="False" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0"
                    BorderThickness="1" BorderBrush="#40808080" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Participants" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding Peers}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PeerViewModel}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" />
                                    <TextBlock Text=" (host)" Opacity="0.6"
                                               Visibility="{Binding IsHost, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2" Text="Sender" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,12,0,4" />
                    <TextBlock Grid.Row="3" Text="{Binding SenderStats}" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Grid.Row="4" Text="Receiver" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,12,0,4" />
                    <TextBlock Grid.Row="5" Text="{Binding ReceiverStats}" FontFamily="Consolas" FontSize="11" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding MediaStatus}" Opacity="0.7" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#FFAA5555"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Settings"
                    Command="{Binding ShowSettingsCommand}" Padding="12,6" />
        </Grid>
    </Grid>
</UserControl>
