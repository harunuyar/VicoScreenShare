<UserControl x:Class="ScreenSharing.Desktop.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ScreenSharing.Desktop.App.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="0,0,0,100">
            <Grid MaxWidth="720" HorizontalAlignment="Center" Margin="24,24,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header: Back chevron + title stack. -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Button Grid.Column="0"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Symbol=ArrowLeft24}"
                               Command="{Binding GoBackCommand}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="Quality changes take effect the next time you start sharing."
                                   Opacity="0.6" FontSize="13" />
                    </StackPanel>
                </Grid>

                <!-- Presets card. Click any preset to fill the sliders
                     below; the dirty tracker catches the property changes
                     and lights up the Save pill. -->
                <ui:Card Grid.Row="1" Margin="0,24,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Presets" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Click a preset to fill the sliders below."
                                   Opacity="0.5" FontSize="12" Margin="0,4,0,12" />
                        <ItemsControl ItemsSource="{Binding QualityPresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:QualityPreset}">
                                    <ui:Button Appearance="Secondary"
                                               Content="{Binding Name}"
                                               Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Margin="0,0,8,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <!-- Video card: resolution / fps / bitrate / keyframe / scaler. -->
                <ui:Card Grid.Row="2" Margin="0,16,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Video" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Target resolution" Opacity="0.7" FontSize="12" />
                            <ComboBox ItemsSource="{Binding TargetHeightOptions}"
                                      SelectedItem="{Binding SelectedTargetHeight}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Frame rate" Opacity="0.7" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding FrameRate, StringFormat={}{0} fps}"
                                           Opacity="0.9" FontSize="12" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="10" Maximum="240" TickFrequency="5" IsSnapToTickEnabled="True"
                                    Value="{Binding FrameRate}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Bitrate" Opacity="0.7" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding BitrateDisplay}"
                                           Opacity="0.9" FontSize="12" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True"
                                    Value="{Binding BitrateSliderValue}" Margin="0,4,0,0" />
                            <TextBlock Text="Logarithmic 500 Kbps – 100 Mbps."
                                       Opacity="0.5" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Keyframe interval" Opacity="0.7" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding KeyframeIntervalSeconds, StringFormat={}{0:0.0} s}"
                                           Opacity="0.9" FontSize="12" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="0.5" Maximum="10" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding KeyframeIntervalSeconds}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Scaler quality" Opacity="0.7" FontSize="12" />
                            <ComboBox ItemsSource="{Binding ScalerQualityOptions}"
                                      SelectedItem="{Binding SelectedScalerQuality}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Receive buffer (jitter absorption)" Opacity="0.7" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding ReceiveBufferFrames, StringFormat={}{0} frames}"
                                           Opacity="0.9" FontSize="12" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="1" Maximum="240" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding ReceiveBufferFrames}" Margin="0,4,0,0" />
                            <TextBlock Text="More frames = smoother under network jitter, more latency. 5 is a good default."
                                       Opacity="0.5" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- Codec card. -->
                <ui:Card Grid.Row="3" Margin="0,16,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Codec" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding CodecOptions}"
                                  SelectedItem="{Binding SelectedCodec}"
                                  DisplayMemberPath="DisplayName" />
                    </StackPanel>
                </ui:Card>

                <ui:InfoBar Grid.Row="4"
                            Title="Settings"
                            Message="{Binding StatusMessage}"
                            Severity="Informational"
                            IsClosable="True"
                            IsOpen="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}, FallbackValue=False}"
                            Margin="0,16,0,0" />
            </Grid>
        </ScrollViewer>

        <!-- Floating Save pill. Only visible when something changed —
             the dirty bit flips on any bound property change and resets
             on a successful save. -->
        <ui:Button Appearance="Primary"
                   Content="Save changes"
                   Icon="{ui:SymbolIcon Symbol=Save24}"
                   Command="{Binding SaveCommand}"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,32,32" Padding="20,10"
                   Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
