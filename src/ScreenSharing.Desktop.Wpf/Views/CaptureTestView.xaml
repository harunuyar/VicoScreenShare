<UserControl x:Class="ScreenSharing.Desktop.App.Views.CaptureTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:rendering="clr-namespace:ScreenSharing.Desktop.App.Rendering"
             xmlns:vm="clr-namespace:ScreenSharing.Desktop.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:CaptureTestViewModel}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Control bar: left-aligned actions + checkbox + status,
             right-aligned settings gear (same position as the gear on
             HomeView). -->
        <Grid Grid.Row="0" Margin="16,16,16,8" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=ArrowLeft24}"
                           Content="Back"
                           Command="{Binding GoBackCommand}" />
                <ui:Button x:Name="PickButton"
                           Appearance="Primary"
                           Content="Pick Source"
                           Margin="8,0,0,0"
                           Click="PickButton_Click" />
                <ui:Button x:Name="StopButton"
                           Appearance="Secondary"
                           Content="Stop"
                           IsEnabled="False"
                           Margin="8,0,0,0"
                           Click="StopButton_Click" />
                <CheckBox x:Name="EncodeDecodeBox"
                          Content="Run through encode/decode"
                          Margin="20,0,0,0"
                          VerticalAlignment="Center"
                          ToolTip="When checked, frames go through the real production CaptureStreamer + H.264 encoder + decoder, and the renderer's Receiver path (jitter buffer + paced paints). Unchecked uses the LocalPreviewSource texture-direct path." />
                <TextBlock x:Name="StatusText" Margin="20,0,0,0"
                           VerticalAlignment="Center" Opacity="0.75" />
            </StackPanel>
            <ui:Button Grid.Column="1"
                       Appearance="Secondary"
                       Icon="{ui:SymbolIcon Symbol=Settings24}"
                       ToolTip="Edit settings"
                       Click="OpenSettings_Click" />
        </Grid>

        <!-- Live stats. Updated every ~500 ms by a DispatcherTimer in
             the code-behind. Empty until a source is picked. -->
        <Border Grid.Row="1" Background="#22000000"
                Padding="16,8" Margin="16,0,16,8" CornerRadius="6">
            <TextBlock x:Name="StatsText"
                       FontFamily="Cascadia Mono, Consolas, Courier New"
                       FontSize="13"
                       Text="No source picked." />
        </Border>

        <Border Grid.Row="2" Background="Black" Margin="0,0,0,0">
            <rendering:D3DImageVideoRenderer x:Name="Renderer" />
        </Border>
    </Grid>
</UserControl>
