<UserControl x:Class="ScreenSharing.Desktop.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ScreenSharing.Desktop.App.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=vm:HomeViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <!-- Top-right action cluster: Capture test next to Settings. Both
             docked to the corner so the hero card stays visually centered. -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,16,24,0">
            <ui:Button Appearance="Secondary"
                       Icon="{ui:SymbolIcon Symbol=Bug24}"
                       ToolTip="Capture test (diagnostic pipeline)"
                       Command="{Binding ShowCaptureTestCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Appearance="Secondary"
                       Icon="{ui:SymbolIcon Symbol=Settings24}"
                       Command="{Binding ShowSettingsCommand}" />
        </StackPanel>

        <ui:Card MaxWidth="440" Padding="28"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ScreenSharing"
                           FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Self-hosted screen share"
                           Opacity="0.55" FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,24" />

                <!-- 6-char uppercase room ID + paste button.
                     MaxLength + the sanitize hook in the VM guarantee the
                     buffer never holds more than 6 valid characters. -->
                <TextBlock Text="Room ID" Opacity="0.7" FontSize="12" />
                <Grid Margin="0,4,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                Text="{Binding JoinRoomId, UpdateSourceTrigger=PropertyChanged}"
                                MaxLength="6"
                                CharacterCasing="Upper"
                                FontFamily="Cascadia Mono, Consolas, Courier New"
                                FontSize="22"
                                HorizontalContentAlignment="Center"
                                PlaceholderText="ABC123" />
                    <ui:Button Grid.Column="1"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Symbol=ClipboardPaste24}"
                               ToolTip="Paste from clipboard"
                               Command="{Binding PasteRoomIdCommand}"
                               Margin="8,0,0,0" />
                </Grid>

                <ui:Button Appearance="Primary"
                           Content="Join room"
                           Icon="{ui:SymbolIcon Symbol=ArrowRight24}"
                           Command="{Binding JoinRoomCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                           HorizontalAlignment="Stretch" />

                <!-- Visual break before the secondary "create instead"
                     action so the user can't accidentally hit Create
                     while reaching for Join. -->
                <Grid Margin="0,20,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Height="1" Fill="#40808080" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="or" Opacity="0.5" FontSize="12"
                               Margin="12,0" VerticalAlignment="Center" />
                    <Rectangle Grid.Column="2" Height="1" Fill="#40808080" VerticalAlignment="Center" />
                </Grid>

                <ui:Button Appearance="Secondary"
                           Content="Create a new room"
                           Icon="{ui:SymbolIcon Symbol=Add24}"
                           Command="{Binding CreateRoomCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                           HorizontalAlignment="Stretch" />

                <ui:InfoBar Title="Heads up"
                            Message="{Binding StatusMessage}"
                            Severity="Warning"
                            IsClosable="True"
                            IsOpen="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}, FallbackValue=False}"
                            Margin="0,16,0,0" />

                <!-- Display name footer: click the pencil to swap the
                     label for an inline TextBox, checkmark commits. -->
                <Grid Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Visibility="{Binding IsEditingDisplayName, Converter={StaticResource InvertBoolToVisibility}}">
                        <TextBlock Text="Joining as " Opacity="0.55" />
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                        <ui:Button Appearance="Transparent"
                                   Icon="{ui:SymbolIcon Symbol=Edit24}"
                                   Command="{Binding BeginEditDisplayNameCommand}"
                                   Margin="4,0,0,0" Padding="4" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Visibility="{Binding IsEditingDisplayName, Converter={StaticResource BoolToVisibility}}">
                        <ui:TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                    MinWidth="200"
                                    PlaceholderText="Display name" />
                        <ui:Button Appearance="Primary"
                                   Icon="{ui:SymbolIcon Symbol=Checkmark24}"
                                   Command="{Binding CommitDisplayNameCommand}"
                                   Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ui:Card>

        <!-- Indeterminate progress ring while a connect is in flight. -->
        <ui:ProgressRing IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                         HorizontalAlignment="Center" VerticalAlignment="Bottom"
                         Margin="0,0,0,32" Width="32" Height="32" />
    </Grid>
</UserControl>
