<ui:FluentWindow x:Class="ScreenSharing.Desktop.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:svc="clr-namespace:ScreenSharing.Desktop.App.Services"
                 Title="ScreenSharing"
                 Width="1280" Height="800"
                 MinWidth="720" MinHeight="500"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <svc:NavigationService />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar — extends content into it so the nav/page
             fills right up to the chrome edge and picks up the Mica
             backdrop underneath. -->
        <ui:TitleBar Grid.Row="0"
                     Title="ScreenSharing"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />

        <!-- NavigationService.Current is the active view model;
             ViewModelToPageConverter maps it to a UserControl. -->
        <ContentControl x:Name="PageHost" Grid.Row="1"
                        Content="{Binding Current, Converter={StaticResource VmToPage}}" />

        <!-- In-window Settings panel. Lives in a Popup so its own top-level
             HWND sits above the page's child HwndHost renderers — the video
             keeps playing underneath, full color, no dimming. Anchored to
             the top-right (near the Settings button that opens it) and
             stretches vertically with a 16px margin from window chrome.
             The transparent backdrop still catches click-outside-to-dismiss. -->
        <Popup IsOpen="{Binding ActiveOverlay, Converter={StaticResource NonNullToBool}}"
               StaysOpen="True"
               AllowsTransparency="True"
               Placement="Center"
               PlacementTarget="{Binding ElementName=PageHost}"
               Width="{Binding ActualWidth, ElementName=PageHost}"
               Height="{Binding ActualHeight, ElementName=PageHost}">
            <!-- Background alpha 1/255: invisible but hit-testable. A fully
                 transparent Background lets clicks fall through the
                 AllowsTransparency popup to the page underneath, so neither
                 StaysOpen=False nor our manual handler would ever see them. -->
            <Grid Background="#01000000" Focusable="True"
                  KeyDown="OnOverlayKeyDown"
                  MouseDown="OnOverlayBackdropMouseDown">
                <Border Width="460"
                        Margin="0,64,16,16"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        ClipToBounds="True"
                        MouseDown="OnOverlayCardMouseDown">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35" />
                    </Border.Effect>
                    <ContentControl Content="{Binding ActiveOverlay, Converter={StaticResource VmToPage}}" />
                </Border>
            </Grid>
        </Popup>
    </Grid>
</ui:FluentWindow>
