<ui:FluentWindow x:Class="ScreenSharing.Desktop.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:svc="clr-namespace:ScreenSharing.Desktop.App.Services"
                 Title="ScreenSharing"
                 Width="1280" Height="800"
                 MinWidth="720" MinHeight="500"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <svc:NavigationService />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar — extends content into it so the nav/page
             fills right up to the chrome edge and picks up the Mica
             backdrop underneath. -->
        <ui:TitleBar Grid.Row="0"
                     Title="ScreenSharing"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />

        <!-- NavigationService.Current is the active view model;
             ViewModelToPageConverter maps it to a UserControl. -->
        <ContentControl Grid.Row="1"
                        Content="{Binding Current, Converter={StaticResource VmToPage}}" />
    </Grid>
</ui:FluentWindow>
