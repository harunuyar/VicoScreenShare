<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScreenSharing.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="ScreenSharing.Client.Views.RoomView"
             x:DataType="vm:RoomViewModel">

    <Grid Margin="24" RowDefinitions="Auto,*,Auto,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Room" Opacity="0.6" FontSize="12" />
                <TextBlock Text="{Binding RoomId}" FontSize="28" FontWeight="Bold" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Share screen"
                    Command="{Binding ShareScreenCommand}"
                    IsEnabled="{Binding CanShareScreen}"
                    IsVisible="{Binding !IsSharing}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />
            <Button Grid.Column="1"
                    Content="Stop sharing"
                    Command="{Binding StopSharingCommand}"
                    IsVisible="{Binding IsSharing}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="Leave room"
                    Command="{Binding LeaveRoomCommand}"
                    VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,0" ColumnDefinitions="*,260">

            <Grid Grid.Column="0" Margin="0,0,12,0" RowDefinitions="*,Auto">

                <Border Grid.Row="0"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#40808080"
                        Background="#10000000">
                    <Grid>
                        <Image Source="{Binding RemoteStream}"
                               Stretch="Uniform"
                               IsVisible="{Binding RemoteStream, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6"
                                    IsVisible="{Binding RemoteStream, Converter={x:Static ObjectConverters.IsNull}}">
                            <TextBlock Text="No incoming stream"
                                       FontSize="14" Opacity="0.6" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding MediaStatus}"
                                       FontSize="12" Opacity="0.4" HorizontalAlignment="Center"
                                       IsVisible="{Binding MediaStatus, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#40FF5050"
                        Background="#10000000"
                        Padding="8"
                        IsVisible="{Binding IsSharing}">
                    <Grid ColumnDefinitions="Auto,*" Height="140">
                        <Image Grid.Column="0"
                               Source="{Binding LocalPreview}"
                               Stretch="Uniform"
                               Width="220"
                               HorizontalAlignment="Left"
                               IsVisible="{Binding LocalPreview, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="#FF5050" VerticalAlignment="Center" />
                                <TextBlock Text="Sharing your screen" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding LocalStreamLabel}"
                                       FontSize="12"
                                       Opacity="0.7"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>

            <Border Grid.Column="1"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#40808080"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="People in this room"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Peers}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:PeerViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <Border CornerRadius="10" Background="#4CAF50" Padding="6,1"
                                            IsVisible="{Binding IsHost}">
                                        <TextBlock Text="host" FontSize="10" Foreground="White" />
                                    </Border>
                                    <Border CornerRadius="10" Background="#4080FF" Padding="6,1"
                                            IsVisible="{Binding IsSelf}">
                                        <TextBlock Text="you" FontSize="10" Foreground="White" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

        </Grid>

        <TextBlock Grid.Row="2"
                   Text="You are the host of this room."
                   IsVisible="{Binding YouAreHost}"
                   Opacity="0.6"
                   Margin="0,12,0,0" />

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                   Margin="0,12,0,0"
                   Foreground="#FFB8A0"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
