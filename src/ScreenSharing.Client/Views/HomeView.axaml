<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScreenSharing.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="ScreenSharing.Client.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <Grid Margin="48" RowDefinitions="Auto,Auto,*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="ScreenSharing" FontSize="32" FontWeight="Bold" />
                <TextBlock Text="Self-hosted screen share. Enter a display name and create or join a room."
                           Opacity="0.6" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Preview capture"
                    Command="{Binding ShowPreviewCommand}"
                    IsVisible="{Binding IsPreviewAvailable}"
                    VerticalAlignment="Top" />
            <Button Grid.Column="2"
                    Content="Settings"
                    Command="{Binding ShowSettingsCommand}"
                    VerticalAlignment="Top"
                    Margin="8,0,0,0" />
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,24,0,0" Spacing="8">
            <TextBlock Text="Display name" />
            <TextBox Text="{Binding DisplayName}"
                     PlaceholderText="e.g. Alice"
                     MaxLength="40" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,32,0,0" ColumnDefinitions="*,24,*">

            <Border Grid.Column="0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#40808080"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Create room" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Password (optional)" Opacity="0.6" FontSize="12" />
                    <TextBox Text="{Binding CreatePassword}" PasswordChar="*" />
                    <Button Content="Create"
                            Command="{Binding CreateRoomCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#40808080"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Join room" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Room id" Opacity="0.6" FontSize="12" />
                    <TextBox Text="{Binding JoinRoomId}" PlaceholderText="ABC123" MaxLength="6" />
                    <TextBlock Text="Password" Opacity="0.6" FontSize="12" />
                    <TextBox Text="{Binding JoinPassword}" PasswordChar="*" />
                    <Button Content="Join"
                            Command="{Binding JoinRoomCommand}"
                            IsEnabled="{Binding !IsBusy}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,12,0,0" />
                </StackPanel>
            </Border>

        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                   Margin="0,16,0,0"
                   Foreground="#FFB8A0"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
