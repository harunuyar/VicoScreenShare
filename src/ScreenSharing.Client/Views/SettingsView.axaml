<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScreenSharing.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="900"
             x:Class="ScreenSharing.Client.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="48" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <Button Grid.Column="0"
                        Content="&#x2190; Back"
                        Command="{Binding GoBackCommand}"
                        VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Video quality applies next time you start sharing."
                               Opacity="0.6" />
                </StackPanel>
            </Grid>

            <!-- Preset buttons. Click fills all sliders below; user can tweak anything after. -->
            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#40808080"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="Presets" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Click a preset to fill the sliders below. Everything is still editable afterwards."
                               Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding QualityPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:QualityPreset">
                                <Button Content="{Binding Name}"
                                        Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).ApplyPresetCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,8"
                                        Padding="14,6" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Video sliders. -->
            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#40808080"
                    Padding="20">
                <StackPanel Spacing="20">
                    <TextBlock Text="Video" FontSize="18" FontWeight="SemiBold" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Target resolution" Opacity="0.7" FontSize="12" />
                        <ComboBox ItemsSource="{Binding TargetHeightOptions}"
                                  SelectedItem="{Binding SelectedTargetHeight}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="vm:TargetHeightOption">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Width is derived from the source aspect ratio at runtime so the output never distorts."
                                   Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Frame rate" Opacity="0.7" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="{Binding FrameRate, StringFormat='{}{0} fps'}"
                                       Opacity="0.9" FontSize="12" />
                        </Grid>
                        <Slider Minimum="10" Maximum="240"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                Value="{Binding FrameRate}" />
                        <TextBlock Text="Incoming frames exceeding this rate are dropped."
                                   Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Bitrate" Opacity="0.7" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="{Binding BitrateDisplay}"
                                       Opacity="0.9" FontSize="12" />
                        </Grid>
                        <Slider Minimum="0" Maximum="1"
                                TickFrequency="0.01" IsSnapToTickEnabled="True"
                                Value="{Binding BitrateSliderValue}" />
                        <TextBlock Text="Logarithmic 500 Kbps - 100 Mbps. Higher = sharper but more bandwidth. 1080p60 wants ~12 Mbps; 1440p120 wants ~25-50 Mbps."
                                   Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Keyframe interval" Opacity="0.7" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="{Binding KeyframeIntervalSeconds, StringFormat='{}{0:0.0} s'}"
                                       Opacity="0.9" FontSize="12" />
                        </Grid>
                        <Slider Minimum="0.5" Maximum="10"
                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                Value="{Binding KeyframeIntervalSeconds}" />
                        <TextBlock Text="Shorter = faster new-viewer join-in, but more bits spent on keyframes. 2s is the default for screen sharing."
                                   Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Scaler quality" Opacity="0.7" FontSize="12" />
                        <ComboBox ItemsSource="{Binding ScalerQualityOptions}"
                                  SelectedItem="{Binding SelectedScalerQuality}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="vm:ScalerQualityOption">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Bilinear is fast and legible for most content. Bicubic/Lanczos give sharper text at a slightly higher GPU cost; runs on the dedicated video hardware, not the 3D pipeline."
                                   Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Codec. -->
            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#40808080"
                    Padding="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Codec" FontSize="18" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding CodecOptions}"
                              SelectedItem="{Binding SelectedCodec}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.Styles>
                            <Style Selector="ComboBoxItem" x:DataType="vm:CodecOption">
                                <Setter Property="IsEnabled" Value="{Binding IsAvailable}" />
                            </Style>
                        </ComboBox.Styles>
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:CodecOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="H.264 uses your GPU's Media Foundation hardware encoder when available."
                               Opacity="0.5" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="4"
                       Text="{Binding StatusMessage}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Margin="0,16,0,0"
                       Opacity="0.8"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12"
                        Margin="0,16,0,0">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="24,8" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
