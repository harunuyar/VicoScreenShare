<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="ScreenSharing.Client.MainWindow"
        Width="1280" Height="800"
        Title="ScreenSharing">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="ScreenSharing" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="Phase 0 skeleton — nothing to see yet" Opacity="0.6" HorizontalAlignment="Center" />
    </StackPanel>
</Window>
