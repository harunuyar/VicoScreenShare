<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ScreenSharing.Client.ViewModels"
             xmlns:views="using:ScreenSharing.Client.Views"
             x:Class="ScreenSharing.Client.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <DataTemplate DataType="vm:HomeViewModel">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="vm:RoomViewModel">
            <views:RoomView />
        </DataTemplate>
        <DataTemplate DataType="vm:PreviewViewModel">
            <views:PreviewView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
