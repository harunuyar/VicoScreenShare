<UserControl x:Class="VicoScreenShare.Desktop.App.Controls.VolumeFlyoutButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root">

    <Grid x:Name="Anchor"
          MouseEnter="OnAnchorMouseEnter"
          MouseLeave="OnAnchorMouseLeave">
        <!-- Speaker button. Click toggles mute; hover reveals the volume
             slider below via the Popup. Icon swaps between speaker and
             speaker-muted so the tile's audio state reads at a glance. -->
        <ui:Button x:Name="SpeakerButton"
                   Appearance="Transparent"
                   Foreground="White"
                   Padding="6"
                   Command="{Binding ToggleMuteCommand, ElementName=Root}">
            <ui:Button.ToolTip>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Mute" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMuted, ElementName=Root}" Value="True">
                                    <Setter Property="Text" Value="Unmute" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </ui:Button.ToolTip>
            <ui:Button.Icon>
                <ui:SymbolIcon>
                    <ui:SymbolIcon.Style>
                        <Style TargetType="ui:SymbolIcon">
                            <Setter Property="Symbol" Value="Speaker224" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMuted, ElementName=Root}" Value="True">
                                    <Setter Property="Symbol" Value="SpeakerMute24" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:SymbolIcon.Style>
                </ui:SymbolIcon>
            </ui:Button.Icon>
        </ui:Button>

        <!-- Slider flyout. PopupAnimation="Fade" gets the open/close
             animation for free; code-behind owns the hover→open and
             timeout→close state so the popup stays open while the mouse
             is on either the button or the slider itself. -->
        <Popup x:Name="Flyout"
               PlacementTarget="{Binding ElementName=SpeakerButton}"
               Placement="Bottom"
               VerticalOffset="4"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               MouseEnter="OnFlyoutMouseEnter"
               MouseLeave="OnFlyoutMouseLeave">
            <Border Background="#EE1E1E1E"
                    CornerRadius="6"
                    BorderBrush="#44FFFFFF"
                    BorderThickness="1"
                    Padding="4,8"
                    Width="{Binding ActualWidth, ElementName=SpeakerButton}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.35" />
                </Border.Effect>
                <Slider Orientation="Vertical"
                        Minimum="0" Maximum="1"
                        SmallChange="0.05" LargeChange="0.1"
                        Height="120"
                        HorizontalAlignment="Center"
                        Value="{Binding Value, ElementName=Root}" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
