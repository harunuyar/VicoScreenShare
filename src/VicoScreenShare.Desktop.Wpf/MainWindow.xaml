<ui:FluentWindow x:Class="VicoScreenShare.Desktop.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:svc="clr-namespace:VicoScreenShare.Desktop.App.Services"
                 xmlns:b="clr-namespace:VicoScreenShare.Desktop.App.Behaviors"
                 xmlns:rendering="clr-namespace:VicoScreenShare.Desktop.App.Rendering"
                 Title="Vico Screen Share"
                 Icon="pack://application:,,,/Assets/VicoScreenShare.ico"
                 Width="1280" Height="800"
                 MinWidth="720" MinHeight="500"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <svc:NavigationService />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar — extends content into it so the nav/page
             fills right up to the chrome edge and picks up the Mica
             backdrop underneath. -->
        <ui:TitleBar Grid.Row="0"
                     Title="Vico Screen Share"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/VicoScreenShare.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- NavigationService.Current is the active view model;
             ViewModelToPageConverter maps it to a UserControl. -->
        <ContentControl x:Name="PageHost" Grid.Row="1"
                        Content="{Binding Current, Converter={StaticResource VmToPage}}" />

        <!-- In-window overlay panel. Hosts Settings (compact, top-right)
             and the Share picker (wide, center). D3DImage-based content
             lives underneath; the overlay composes over it through WPF's
             normal rendering path — no HwndHost / layered-window issues
             because neither the renderer nor the overlay uses one. -->
        <Grid Grid.Row="1"
              Panel.ZIndex="100"
              Background="#60000000"
              Focusable="True"
              Visibility="{Binding ActiveOverlay, Converter={StaticResource NullToCollapsed}}"
              KeyDown="OnOverlayKeyDown"
              MouseDown="OnOverlayBackdropMouseDown">
            <!-- CutoutForAll on the card (not the dimmed backdrop) so
                 renderers below the overlay punch a hole under the card
                 itself, leaving the dimmed backdrop to overlay the video
                 naturally. Renderers INSIDE the card (e.g. picker tile
                 previews) skip this cutout via the ancestor-skip check
                 in UpdateWindowRegion. -->
            <Border Width="{Binding OverlayWidth}"
                    MaxHeight="{Binding OverlayMaxHeight}"
                    Margin="{Binding OverlayMargin}"
                    Background="{DynamicResource ApplicationBackgroundBrush}"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    HorizontalAlignment="{Binding OverlayHorizontalAlignment}"
                    VerticalAlignment="{Binding OverlayVerticalAlignment}"
                    ClipToBounds="True"
                    rendering:D3DImageVideoRenderer.CutoutForAll="True"
                    MouseDown="OnOverlayCardMouseDown">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35" />
                </Border.Effect>
                <ContentControl Content="{Binding ActiveOverlay, Converter={StaticResource VmToPage}}" />
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
