<UserControl x:Class="VicoScreenShare.Desktop.App.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VicoScreenShare.Desktop.App.ViewModels"
             xmlns:rendering="clr-namespace:VicoScreenShare.Desktop.App.Rendering"
             xmlns:ctl="clr-namespace:VicoScreenShare.Desktop.App.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=vm:RoomViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Shared style for chrome overlays that fade on mouse idle.
             Opacity animates on the IsChromeVisible room-VM flag;
             IsHitTestVisible follows so invisible chrome can't receive
             clicks. Fade-in is snappier than fade-out (150 ms vs
             300 ms) to match how users perceive the reappear-on-
             activity action as "instant." -->
        <Style x:Key="AutoHideChromeStyle" TargetType="FrameworkElement">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsChromeVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                    <Setter Property="IsHitTestVisible" Value="False" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Tile template shared between Grid mode, Focus mode's main
             slot, and Focus mode's bottom strip. Single source of
             truth for the renderer + paused overlay + chrome bar +
             click-to-focus. The D3DImage-based renderer composites as
             a normal WPF visual, so chrome and overlays stack above
             it without airspace tricks. -->
        <DataTemplate x:Key="PublisherTileTemplate" DataType="{x:Type vm:PublisherTileViewModel}">
            <Border x:Name="TileRoot"
                    Margin="3"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#33FFFFFF"
                    ClipToBounds="True"
                    Background="#FF0A0A0A"
                    Cursor="Hand"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <!-- Click/double-click via normal WPF routed events on
                     the Border. -->
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding Tag.FocusTileCommand, ElementName=TileRoot}"
                                  CommandParameter="{Binding PublisherPeerId}" />
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding Tag.ToggleFullscreenCommand, ElementName=TileRoot}"
                                  CommandParameter="{Binding PublisherPeerId}" />
                </Border.InputBindings>
                <Grid>
                    <!-- D3D renderer fills the entire tile. -->
                    <rendering:D3DImageVideoRenderer x:Name="TileRenderer"
                                                     Receiver="{Binding Receiver}"
                                                     NominalFrameRate="{Binding NominalFrameRate}"
                                                     CornerRadius="10"
                                                     Visibility="{Binding HasFirstFrame, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="Connecting…"
                               Foreground="#AAFFFFFF" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasFirstFrame, Converter={StaticResource InvertBoolToVisibility}}" />

                    <!-- Reconnecting overlay — transient: ICE went disconnected,
                         or the publisher's WebSocket is in its server-side grace
                         window. Last decoded frame stays painted underneath. -->
                    <Grid Background="#80000000"
                          Visibility="{Binding IsReconnecting, Converter={StaticResource BoolToVisibility}}"
                          IsHitTestVisible="False">
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#CC1E1E1E" CornerRadius="14" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowSync24" FontSize="16" Foreground="White"
                                               VerticalAlignment="Center" />
                                <TextBlock Text="Reconnecting…" Foreground="White"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Connection lost overlay — terminal: ICE failed/closed
                         without a graceful PeerLeft. Tile is normally unmounted
                         shortly after by RoomViewModel; this is the fallback. -->
                    <Grid Background="#80000000"
                          Visibility="{Binding IsLost, Converter={StaticResource BoolToVisibility}}"
                          IsHitTestVisible="False">
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#CC1E1E1E" CornerRadius="14" Padding="16,8">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="PlugDisconnected24" FontSize="16" Foreground="White"
                                               VerticalAlignment="Center" />
                                <TextBlock Text="Connection lost" Foreground="White"
                                           FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Display name: rounded pill, bottom-left.
                         Auto-hides after mouse idle via shared style. -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="10"
                            Background="#B3000000"
                            CornerRadius="4"
                            Padding="8,3"
                            IsHitTestVisible="False"
                            Style="{StaticResource AutoHideChromeStyle}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="White"
                                   FontSize="12" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280" />
                    </Border>

                    <!-- Controls pill: top-right. Auto-hides after
                         mouse idle via shared style. -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="8"
                            Background="#B3000000"
                            CornerRadius="20"
                            Padding="2"
                            Style="{StaticResource AutoHideChromeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <!-- Speaker button with a hover-revealed volume
                                 slider that fades in, anchored below. Own
                                 state machine handles the
                                 button-or-slider hover + timeout-close. -->
                            <ctl:VolumeFlyoutButton
                                Value="{Binding Volume, Mode=TwoWay}"
                                IsMuted="{Binding IsMuted, Mode=TwoWay}"
                                ToggleMuteCommand="{Binding ToggleMuteCommand}" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon Symbol=FullScreenMaximize24}"
                                       Foreground="White"
                                       ToolTip="Fullscreen (double-click)"
                                       Padding="6"
                                       Command="{Binding Tag.ToggleFullscreenCommand, ElementName=TileRoot}"
                                       CommandParameter="{Binding PublisherPeerId}" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon Symbol=EyeOff24}"
                                       Foreground="White"
                                       ToolTip="Stop watching"
                                       Padding="6"
                                       Command="{Binding Tag.StopWatchingCommand, ElementName=TileRoot}"
                                       CommandParameter="{Binding PublisherPeerId}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Root Grid swaps between normal content and fullscreen overlay on
         IsFullscreen. Two sibling children in the same Grid: normal visible
         when !IsFullscreen, overlay visible when IsFullscreen. -->
    <Grid>

    <!-- Outer 2-column layout. Column 0 holds the room (top bar +
         video area + footer); column 1 holds the stats sidebar which
         only takes space when IsStatsPanelOpen. The room shrinks
         automatically when the panel opens — no overlap. -->
    <Grid Visibility="{Binding IsFullscreen, Converter={StaticResource InvertBoolToVisibility}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="16,8,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: room id chip on the left, Stats + Settings + Leave on the right. -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            CornerRadius="14"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding ConnectionDotBrush}"
                                     VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding RoomId}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <ui:Button Appearance="Transparent"
                                       Icon="{ui:SymbolIcon Symbol=Copy24}"
                                       ToolTip="Copy room ID"
                                       Click="OnCopyRoomIdClick"
                                       Padding="4" Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Reconnect chip: visible only while the client is inside
                         the server-side grace window trying to resume. -->
                    <Border Background="#FFB78100"
                            CornerRadius="14"
                            Padding="10,6"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsReconnecting, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14" Foreground="White"
                                           VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ReconnectMessage}"
                                       Foreground="White" FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Share / Stop lives in the top bar so it's always reachable
                     without scrolling the member strip. Primary appearance
                     while idle (call to action), Danger while sharing so the
                     stop control stands out. -->
                <ui:Button Grid.Column="2"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Symbol=Share24}"
                           Content="Share screen"
                           Command="{Binding ShareScreenCommand}"
                           Visibility="{Binding IsSharing, Converter={StaticResource InvertBoolToVisibility}}" />
                <ui:Button Grid.Column="2"
                           Appearance="Danger"
                           Icon="{ui:SymbolIcon Symbol=DismissCircle24}"
                           Content="Stop sharing"
                           Command="{Binding StopSharingCommand}"
                           Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibility}}" />

                <!-- Layout toggle: Grid ↔ Focus (speaker view). Disabled when
                     there are no tiles — nothing to focus on. -->
                <ui:Button Grid.Column="3"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=Apps24}"
                           Command="{Binding ToggleLayoutCommand}"
                           ToolTip="Toggle layout (Grid / Focus)"
                           IsEnabled="{Binding HasAnyTile}"
                           Margin="8,0,0,0" />
                <ui:Button Grid.Column="4"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=DataPie24}"
                           Command="{Binding ToggleStatsPanelCommand}"
                           ToolTip="Stream stats"
                           Margin="8,0,0,0" />
                <ui:Button Grid.Column="5"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=Settings24}"
                           Command="{Binding ShowSettingsCommand}"
                           ToolTip="Settings"
                           Margin="8,0,0,0" />
                <ui:Button Grid.Column="6"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=SignOut24}"
                           Content="Leave"
                           Command="{Binding LeaveRoomCommand}"
                           Margin="8,0,0,0" />
            </Grid>

            <!-- Video area. The self-preview used to live in its own row under
                 the tile grid, eating real estate even when the user was
                 happy with 320x180 in a corner. Now it's a floating child
                 of the tile area (below), draggable + collapsible. -->
            <Grid Grid.Row="1">
                <Border CornerRadius="8" ClipToBounds="True"
                        Background="Black">
                    <Grid>
                        <!-- Empty-state text when no publishers are mounted. Hidden
                             once at least one tile is in the grid. -->
                        <TextBlock Text="{Binding MediaStatus, TargetNullValue='Waiting for a streamer...'}"
                                   Foreground="#CCFFFFFF"
                                   FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding HasAnyTile, Converter={StaticResource InvertBoolToVisibility}}" />

                        <!-- GRID LAYOUT: uniform grid of tiles, sized via TileLayoutConverter. -->
                        <ItemsControl ItemsSource="{Binding Tiles}"
                                      ItemTemplate="{StaticResource PublisherTileTemplate}"
                                      Visibility="{Binding CurrentLayout, Converter={StaticResource LayoutToVisibility}, ConverterParameter=Grid}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding TileCount, Converter={StaticResource TileLayoutColumns}}"
                                                 Rows="{Binding TileCount, Converter={StaticResource TileLayoutRows}}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- FOCUS LAYOUT: one big tile + horizontal bottom strip of everyone else. -->
                        <Grid Visibility="{Binding CurrentLayout, Converter={StaticResource LayoutToVisibility}, ConverterParameter=Focus}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Focused tile. ContentControl re-uses PublisherTileTemplate against
                                 FocusedTile so the renderer, hover controls, and Stop Watching all
                                 work identically to Grid mode. -->
                            <ContentControl Grid.Row="0"
                                            Content="{Binding FocusedTile}"
                                            ContentTemplate="{StaticResource PublisherTileTemplate}" />

                            <!-- Bottom strip: every tile except the focused one. Collapsed when
                                 there's only one tile — otherwise the strip's top margin
                                 claims vertical space and the focused tile renders 4 px
                                 shorter than Grid view's same-size tile, producing a
                                 confusing jolt when the user toggles layouts.
                                 Wrapped in a ScrollViewer so many publishers can scroll
                                 horizontally instead of shrinking off the right edge. -->
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Margin="0,4,0,0"
                                          Visibility="{Binding HasFocusStripItems, Converter={StaticResource BoolToVisibility}}">
                                <ItemsControl ItemsSource="{Binding Tiles}"
                                              ItemTemplate="{StaticResource PublisherTileTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <!-- Hide the focused tile inside the strip — ContentControl above
                                         owns it. Style trigger on the container, not the template. -->
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Width" Value="240" />
                                            <Setter Property="Height" Value="135" />
                                            <Setter Property="Margin" Value="4,0,0,0" />
                                            <Style.Triggers>
                                                <!-- Hide the focused tile inside the strip — the big slot above
                                                     renders it, and we don't want a duplicate rendering. -->
                                                <DataTrigger Binding="{Binding IsFocused}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Self-preview: pinned to bottom-right of the video area with
                             a fixed 16 px inset. Not draggable — keeps the UI simple. -->
                        <Border x:Name="SelfPreviewBorder"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="16"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="#66FFFFFF"
                                Background="#FF0A0A0A"
                                ClipToBounds="True"
                                Visibility="{Binding IsSharing, Converter={StaticResource BoolToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Width" Value="320" />
                                    <Setter Property="Height" Value="180" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelfPreviewCollapsed}" Value="True">
                                            <Setter Property="Width" Value="120" />
                                            <Setter Property="Height" Value="32" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <rendering:D3DImageVideoRenderer x:Name="SelfRenderer"
                                                                 LocalPreviewSource="{Binding LocalPreviewSource}"
                                                                 CornerRadius="10"
                                                                 Visibility="{Binding IsSelfPreviewCollapsed, Converter={StaticResource InvertBoolToVisibility}}" />

                                <!-- Chrome strip: LIVE pill + collapse
                                     chevron. Composes over the self-
                                     preview via WPF Z-order. -->
                                <Grid VerticalAlignment="Top" Height="28"
                                      Background="#80000000">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Margin="8,0,0,0"
                                            Background="#CCD13A3A"
                                            CornerRadius="10"
                                            Padding="7,2"
                                            IsHitTestVisible="False">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="White"
                                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBlock Text="LIVE" Foreground="White"
                                                       FontWeight="Bold" FontSize="9"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <ui:Button Grid.Column="1"
                                               Appearance="Transparent"
                                               Foreground="White"
                                               ToolTip="Collapse / expand self-preview"
                                               Padding="4" Margin="0,0,6,0"
                                               Command="{Binding ToggleSelfPreviewCollapsedCommand}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon>
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="ChevronDown24" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelfPreviewCollapsed}" Value="True">
                                                                <Setter Property="Symbol" Value="ChevronUp24" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer: members strip. Share/Stop now lives in the top bar. -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Peers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PeerViewModel}">
                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="20"
                                        Padding="6,4,12,4"
                                        Margin="0,0,8,0"
                                        ToolTip="{Binding IsConnected, Converter={StaticResource PeerConnectionTooltip}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                    <Setter Property="Opacity" Value="0.45" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="32" Height="32" CornerRadius="16"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="White" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                                        <Ellipse Width="8" Height="8" Fill="#FFD13A3A"
                                                 VerticalAlignment="Center" Margin="6,0,0,0"
                                                 ToolTip="Streaming"
                                                 Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisibility}}" />
                                        <!-- Watch button: appears only when this peer is streaming AND
                                             the local user previously stopped watching them. Click
                                             re-subscribes via the SFU; the tile remounts on SDP offer. -->
                                        <ui:Button Appearance="Transparent"
                                                   Icon="{ui:SymbolIcon Symbol=Eye24}"
                                                   ToolTip="Watch"
                                                   Padding="4" Margin="4,0,0,0"
                                                   Command="{Binding DataContext.WatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding PeerId}">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                                <Condition Binding="{Binding IsWatching}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <TextBlock Text="(you)" Opacity="0.5" FontSize="11"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   Visibility="{Binding IsSelf, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Right-edge stats panel. Visible only when IsStatsPanelOpen.
             Width is fixed; the main column auto-shrinks to fit. -->
        <Border Grid.Column="1"
                Width="320"
                Margin="0,8,16,16"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsStatsPanelOpen, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="16,12,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Stream stats"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1"
                               Appearance="Transparent"
                               Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                               Command="{Binding CloseStatsPanelCommand}"
                               Padding="4"
                               ToolTip="Close" />
                </Grid>

                <ScrollViewer Grid.Row="1" Padding="12,0,12,12"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ui:Card Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="14" />
                                    <TextBlock Text="Outgoing (you)" FontWeight="SemiBold"
                                               Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding OutgoingStats}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11" Opacity="0.85" />
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" />
                                    <TextBlock Text="Incoming" FontWeight="SemiBold"
                                               Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding IncomingStats}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11" Opacity="0.85" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>

        <!-- Fullscreen overlay: one tile fills the entire UserControl. The
             normal content above collapses when IsFullscreen flips true.
             Uses the same PublisherTileTemplate so hover controls (including
             Fullscreen toggle) still work as an exit affordance. -->
        <Border Background="Black"
                Visibility="{Binding IsFullscreen, Converter={StaticResource BoolToVisibility}}">
            <ContentControl Content="{Binding FullscreenTile}"
                            ContentTemplate="{StaticResource PublisherTileTemplate}" />
        </Border>

    </Grid>
</UserControl>
