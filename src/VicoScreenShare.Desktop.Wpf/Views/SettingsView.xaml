<UserControl x:Class="VicoScreenShare.Desktop.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VicoScreenShare.Desktop.App.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Three-row layout tuned for the side-panel popup: a compact sticky
         header, the scrollable settings body, and a docked footer with the
         Save button that's always visible (disabled until something changes).
         The old floating Save pill needed 100 px of dead bottom padding to
         avoid occluding content — this layout gets that space back. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: Close + title. Smaller than the old 28 pt page-hero
             heading so it fits the panel chrome. -->
        <Grid Grid.Row="0" Margin="16,16,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                       Command="{Binding CloseCommand}"
                       ToolTip="Close"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Settings"
                       FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="12,0,0,0" />
        </Grid>

        <!-- Scrollable body. Cards stack vertically with Stretch so none
             of them exceed the panel width. -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,0,16,16">
            <StackPanel>

                <ui:Card Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="Presets" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Click a preset to fill the sliders below."
                                   Opacity="0.55" FontSize="11" Margin="0,2,0,10" />
                        <ItemsControl ItemsSource="{Binding QualityPresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:QualityPreset}">
                                    <ui:Button Appearance="Secondary"
                                               Content="{Binding Name}"
                                               Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Margin="0,0,6,6" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="Video" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Target resolution" Opacity="0.7" FontSize="11" />
                            <ComboBox ItemsSource="{Binding TargetHeightOptions}"
                                      SelectedItem="{Binding SelectedTargetHeight}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Frame rate" Opacity="0.7" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding FrameRate, StringFormat={}{0} fps}"
                                           Opacity="0.9" FontSize="11" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="10" Maximum="240" TickFrequency="5" IsSnapToTickEnabled="True"
                                    Value="{Binding FrameRate}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Bitrate" Opacity="0.7" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding BitrateDisplay}"
                                           Opacity="0.9" FontSize="11" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True"
                                    Value="{Binding BitrateSliderValue}" Margin="0,4,0,0" />
                            <TextBlock Text="Logarithmic 500 Kbps – 100 Mbps."
                                       Opacity="0.5" FontSize="10" Margin="0,3,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Keyframe interval" Opacity="0.7" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding KeyframeIntervalSeconds, StringFormat={}{0:0.0} s}"
                                           Opacity="0.9" FontSize="11" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="0.5" Maximum="10" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding KeyframeIntervalSeconds}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Downscale filter" Opacity="0.7" FontSize="11" />
                            <ComboBox ItemsSource="{Binding ScalerModeOptions}"
                                      SelectedItem="{Binding SelectedScalerMode}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Receive buffer" Opacity="0.7" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding ReceiveBufferFrames, StringFormat={}{0} frames}"
                                           Opacity="0.9" FontSize="11" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>
                            <Slider Minimum="1" Maximum="240" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding ReceiveBufferFrames}" Margin="0,4,0,0" />
                            <TextBlock Text="More frames = smoother under jitter, more latency."
                                       Opacity="0.5" FontSize="10" Margin="0,3,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="Codec" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding CodecOptions}"
                                  SelectedItem="{Binding SelectedCodec}"
                                  DisplayMemberPath="DisplayName"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="Adaptive bitrate" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12" Margin="0,0,0,8"
                                   Text="When on, the publisher lowers its encoder bitrate if any viewer is losing packets (either on the upstream link or server-to-viewer). Frees a struggling viewer; slightly reduces quality while active. Turn off to force the configured target bitrate." />
                        <ui:ToggleSwitch IsChecked="{Binding EnableAdaptiveBitrate}"
                                         OffContent="Off — always use the configured target bitrate"
                                         OnContent="On — respond to downstream congestion" />
                    </StackPanel>
                </ui:Card>

                <ui:InfoBar Title="Settings"
                            Message="{Binding StatusMessage}"
                            Severity="Informational"
                            IsClosable="True"
                            IsOpen="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}, FallbackValue=False}"
                            Margin="0,12,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Docked footer: thin separator + right-aligned Save button. The
             button is always mounted but only enabled when IsDirty is true,
             so the user always knows where it is and save is one click away.
             No floating pill, no reserved bottom padding. -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="16,12">
            <ui:Button Appearance="Primary"
                       Content="Save changes"
                       Icon="{ui:SymbolIcon Symbol=Save24}"
                       Command="{Binding SaveCommand}"
                       IsEnabled="{Binding IsDirty}"
                       HorizontalAlignment="Right" />
        </Border>
    </Grid>
</UserControl>
