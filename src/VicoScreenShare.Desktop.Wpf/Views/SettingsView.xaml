<UserControl x:Class="VicoScreenShare.Desktop.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VicoScreenShare.Desktop.App.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Section header used to group cards under "Video" / "Audio". -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>

        <!-- Card sub-header used for cards whose role isn't obvious
             from the inline label of their single control (e.g. Codec,
             Adaptive bitrate). Cards whose first row is already a
             labelled control don't need it. -->
        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- The little (i) next to each label. Tooltip is set per-instance. -->
        <Style x:Key="InfoIcon" TargetType="ui:SymbolIcon">
            <Setter Property="Symbol" Value="Info20" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            <Setter Property="Cursor" Value="Help" />
        </Style>
    </UserControl.Resources>

    <!-- Three-row layout tuned for the side-panel popup: a compact sticky
         header, the scrollable settings body, and a docked footer with the
         Save button that's always visible (disabled until something changes). -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,16,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                       Command="{Binding CloseCommand}"
                       ToolTip="Close"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Settings"
                       FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="12,0,0,0" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,0,16,16">
            <StackPanel>

                <!-- ═══════ VIDEO ═══════ -->
                <TextBlock Text="Video" Style="{StaticResource SectionHeader}" />

                <!-- Presets -->
                <ui:Card Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Presets" Style="{StaticResource CardHeader}" />
                            <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                           ToolTip="Click a preset to fill in resolution, frame rate, bitrate, and keyframe interval below.&#10;&#10;Applies on your next share." />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding QualityPresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:QualityPreset}">
                                    <ui:Button Appearance="Secondary"
                                               Content="{Binding Name}"
                                               Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Margin="0,0,6,6" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

                <!-- Quality (resolution / fps / bitrate / keyframe / scaler / receive buffer) -->
                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Target resolution" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Encoder target height in pixels. Width is derived from your source's aspect ratio so the picture isn't distorted. Smaller = less bandwidth and less GPU work.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding TargetHeightOptions}"
                                      SelectedItem="{Binding SelectedTargetHeight}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Frame rate" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Cap on how many frames per second the encoder accepts. The capture source may deliver fewer if the shared content isn't moving.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding FrameRateOptions}"
                                      SelectedItem="{Binding FrameRate}"
                                      ItemStringFormat="{}{0} fps"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Bitrate" Style="{StaticResource FieldLabel}" />
                                    <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                                   ToolTip="Encoder target bitrate. Higher = better quality and more upload bandwidth. Slider is logarithmic from 500 Kbps to 100 Mbps.&#10;&#10;Applies on your next share." />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BitrateDisplay}"
                                           Style="{StaticResource FieldValue}" />
                            </Grid>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True"
                                    Value="{Binding BitrateSliderValue}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Keyframe interval" Style="{StaticResource FieldLabel}" />
                                    <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                                   ToolTip="How often the encoder emits a full keyframe. Shorter = new viewers see a clean picture sooner after joining or after packet loss, but more bandwidth is spent on keyframes.&#10;&#10;Applies on your next share." />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding KeyframeIntervalSeconds, StringFormat={}{0:0.0} s}"
                                           Style="{StaticResource FieldValue}" />
                            </Grid>
                            <Slider Minimum="0.5" Maximum="10" TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Value="{Binding KeyframeIntervalSeconds}" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Downscale filter" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Algorithm used when scaling your source down to the target resolution. Bilinear is fast and good for video and gaming. Lanczos is slower but produces sharper text — better for code sessions.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding ScalerModeOptions}"
                                      SelectedItem="{Binding SelectedScalerMode}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Receive buffer" Style="{StaticResource FieldLabel}" />
                                    <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                                   ToolTip="Frames buffered before painting incoming video. More frames = smoother under network jitter, more latency.&#10;&#10;Applies when receiving — to streams started after you save. Streams already on screen keep the value they were created with." />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ReceiveBufferFrames, StringFormat={}{0} frames}"
                                           Style="{StaticResource FieldValue}" />
                            </Grid>
                            <Slider Minimum="1" Maximum="240" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding ReceiveBufferFrames}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- Codec -->
                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Codec" Style="{StaticResource CardHeader}" />
                            <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                           ToolTip="Video codec used to compress your share. VP8 always works (software). H.264 uses your GPU's hardware encoder when available. AV1 needs a newer GPU.&#10;&#10;Applies on your next share." />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding CodecOptions}"
                                  SelectedItem="{Binding SelectedCodec}"
                                  DisplayMemberPath="DisplayName"
                                  HorizontalAlignment="Stretch" />

                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding IsH264Selected, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="H.264 encoder" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Auto picks the direct NVENC SDK on NVIDIA GPUs (faster, exposes adaptive quantization / lookahead / intra-refresh) and falls back to Media Foundation on other hardware. Force Media Foundation if you want the legacy path or are A/B comparing. Direct NVENC SDK only appears when your GPU supports it.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding H264BackendOptions}"
                                      SelectedItem="{Binding SelectedH264Backend}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- Adaptive bitrate -->
                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Adaptive bitrate" Style="{StaticResource CardHeader}" />
                            <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                           ToolTip="When on, your encoder lowers its bitrate if a viewer reports packet loss, then recovers as the link clears. Off forces the configured target bitrate at all times.&#10;&#10;Applies on your next share." />
                        </StackPanel>
                        <ui:ToggleSwitch IsChecked="{Binding EnableAdaptiveBitrate}"
                                         OffContent="Off"
                                         OnContent="On" />
                    </StackPanel>
                </ui:Card>

                <!-- Send pacing -->
                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Smooth keyframe sends" Style="{StaticResource CardHeader}" />
                            <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                           ToolTip="Releases your encoded RTP packets at a steady bitrate instead of dumping each frame onto the wire as a burst. Stops a big keyframe from overrunning a viewer's downlink and dropping packets. Adds latency proportional to (keyframe size / pace rate) — typically a few hundred ms once at session start, absorbed by the receiver's content-time pacer.&#10;&#10;Applies on your next share." />
                        </StackPanel>
                        <ui:ToggleSwitch IsChecked="{Binding EnableSendPacing}"
                                         OffContent="Off"
                                         OnContent="On" />

                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding EnableSendPacing, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Pace rate" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Multiplier on your encoder's target bitrate. ×1 paces wire packets at exactly the encoder's rate — smoothest output, longest one-time keyframe latency. Higher multipliers let the pacer release packets faster, shortening the keyframe transit at the cost of larger wire bursts.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding SendPacingMultiplierOptions}"
                                      SelectedItem="{Binding SendPacingBitrateMultiplier}"
                                      ItemStringFormat="×{0}"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- NVENC quality knobs — only when NVENC is the active backend
                     (codec=H.264 + GPU supports it + user didn't force MFT). -->
                <ui:Card Margin="0,12,0,0" Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                         Visibility="{Binding IsNvencActiveForQualityCard, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="NVENC quality" Style="{StaticResource CardHeader}" />
                            <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                           ToolTip="Direct NVENC SDK encoder knobs that the Windows Media Foundation shim silently ignored. Only available on NVIDIA GPUs with current drivers; greyed otherwise.&#10;&#10;Applies on your next share." />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Adaptive quantization" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Shifts bit budget toward complex regions like text and edges, away from flat areas. Single biggest quality knob for screen content. Recommended on." />
                            </StackPanel>
                            <ui:ToggleSwitch IsChecked="{Binding EnableAdaptiveQuantization}"
                                             OffContent="Off"
                                             OnContent="On" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12"
                                    IsEnabled="{Binding NvencSupportsIntraRefresh}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Intra-refresh" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Replaces periodic IDR keyframes with gradual refresh slices spread over a window. Halves worst-case per-frame size at GOP boundaries. Recommended on." />
                            </StackPanel>
                            <ui:ToggleSwitch IsChecked="{Binding EnableIntraRefresh}"
                                             OffContent="Off"
                                             OnContent="On" />
                        </StackPanel>

                        <StackPanel IsEnabled="{Binding NvencSupportsLookahead}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Encoder lookahead" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Encoder peeks at the next 8 frames before committing rate decisions for the current one. Improves quality but adds ~8 frames of encode-side latency. Off by default; turn on for readability-first scenarios." />
                            </StackPanel>
                            <ui:ToggleSwitch IsChecked="{Binding EnableEncoderLookahead}"
                                             OffContent="Off"
                                             OnContent="On" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- ═══════ AUDIO ═══════ -->
                <TextBlock Text="Audio" Style="{StaticResource SectionHeader}" Margin="2,20,0,8" />

                <ui:Card Padding="16"
                         HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Capture mode" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="&quot;Window only&quot; captures audio just from the app you're sharing. &quot;Whole system&quot; captures everything playing on your machine. Whole-screen shares always use the system mix regardless of this setting. Your microphone is never captured.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ui:ToggleSwitch IsChecked="{Binding ForceSystemAudio}"
                                             OffContent="Window only"
                                             OnContent="Whole system" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Opus bitrate" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Audio encoder bitrate. Higher = closer to source quality, more upload bandwidth.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding AudioBitrateOptions}"
                                      SelectedItem="{Binding SelectedAudioBitrate}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Channels" Style="{StaticResource FieldLabel}" />
                                <ui:SymbolIcon Style="{StaticResource InfoIcon}"
                                               ToolTip="Stereo preserves left/right separation but roughly doubles the audio bitrate. Mono is enough for voice-only content.&#10;&#10;Applies on your next share." />
                            </StackPanel>
                            <ui:ToggleSwitch IsChecked="{Binding AudioStereo}"
                                             OffContent="Mono"
                                             OnContent="Stereo" />
                        </StackPanel>

                    </StackPanel>
                </ui:Card>

                <ui:InfoBar Title="Settings"
                            Message="{Binding StatusMessage}"
                            Severity="Informational"
                            IsClosable="True"
                            IsOpen="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}, FallbackValue=False}"
                            Margin="0,12,0,0" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="16,12">
            <ui:Button Appearance="Primary"
                       Content="Save changes"
                       Icon="{ui:SymbolIcon Symbol=Save24}"
                       Command="{Binding SaveCommand}"
                       IsEnabled="{Binding IsDirty}"
                       HorizontalAlignment="Right" />
        </Border>
    </Grid>
</UserControl>
