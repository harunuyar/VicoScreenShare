<UserControl x:Class="VicoScreenShare.Desktop.App.Views.SharePickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VicoScreenShare.Desktop.App.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:rendering="clr-namespace:VicoScreenShare.Desktop.App.Rendering"
             d:DataContext="{d:DesignInstance Type=vm:SharePickerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Tile template: thumbnail + icon overlay + title + subtitle.
             Selection is driven by a MultiBinding so the selected tile's
             border snaps to the accent color and the rest stay muted.
             The tile is a Button so keyboard focus + Enter / Space work
             for accessibility. -->
        <DataTemplate x:Key="CaptureTargetTileTemplate" DataType="{x:Type vm:CaptureTargetTileViewModel}">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="4"
                    Cursor="Hand"
                    Command="{Binding DataContext.SelectTileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                BorderThickness="2"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                Padding="8">
                            <StackPanel>
                                <Grid Height="160" Width="264">
                                    <!-- Dark placeholder behind the preview so there's
                                         something to look at while WGC warms up. -->
                                    <Border Background="#15FFFFFF" CornerRadius="4" />

                                    <!-- Live preview via the same D3DImage renderer the
                                         room uses for its self-preview. The renderer
                                         returns HTTRANSPARENT from WM_NCHITTEST so
                                         mouse input flows through to the wrapping
                                         Button — no special click plumbing needed. -->
                                    <rendering:D3DImageVideoRenderer
                                        LocalPreviewSource="{Binding CaptureSource}"
                                        CornerRadius="4"
                                        IsAlwaysTopmost="False" />

                                    <!-- Spinner while the first frame is on its way. -->
                                    <ui:ProgressRing IsIndeterminate="True"
                                                     Width="28" Height="28"
                                                     IsHitTestVisible="False"
                                                     Visibility="{Binding ThumbnailLoading, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                                <Grid Margin="2,8,2,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0"
                                           Source="{Binding IconSource}"
                                           Width="16" Height="16"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Vertical">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="228" />
                                        <TextBlock Text="{Binding OwnerDisplayName}"
                                                   FontSize="10" Opacity="0.55"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: close on the left, title in the middle, gear on the
             right. Gear opens the saved Settings dialog so quality tuning
             stays in one place instead of being duplicated in the picker. -->
        <Grid Grid.Row="0" Margin="20,20,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                       Command="{Binding CancelCommand}"
                       ToolTip="Cancel"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Share your screen"
                       FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="12,0,0,0" />
            <ui:Button Grid.Column="2"
                       Appearance="Transparent"
                       Icon="{ui:SymbolIcon Symbol=Settings24}"
                       Command="{Binding OpenSettingsCommand}"
                       ToolTip="Share quality settings"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Tabs: Windows / Screens. Pill-style toggle so the current tab
             is visually distinct. Counts render inline so the user can
             tell at a glance when a tab is empty. -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,12">
            <ui:Button Appearance="{Binding IsWindowsTabActive, Converter={StaticResource BoolToAccentTransparent}}"
                       Command="{Binding SelectTabCommand}"
                       CommandParameter="Windows"
                       Padding="12,6"
                       Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Window24" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock>
                        <Run Text="Windows" />
                        <Run Text=" (" /><Run Text="{Binding WindowTiles.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                </StackPanel>
            </ui:Button>
            <ui:Button Appearance="{Binding IsScreensTabActive, Converter={StaticResource BoolToAccentTransparent}}"
                       Command="{Binding SelectTabCommand}"
                       CommandParameter="Screens"
                       Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Desktop24" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock>
                        <Run Text="Screens" />
                        <Run Text=" (" /><Run Text="{Binding MonitorTiles.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>
                </StackPanel>
            </ui:Button>
        </StackPanel>

        <!-- Tile grid. Two ItemsControls share the same area; only the
             active one is visible. Separate collections keeps the binding
             simple vs filtering on the fly. -->
        <ScrollViewer Grid.Row="2"
                      Padding="16,0,16,0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Loading state for initial enumeration. -->
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="32" Height="32"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0" />

                <ItemsControl ItemsSource="{Binding WindowTiles}"
                              Visibility="{Binding IsWindowsTabActive, Converter={StaticResource BoolToVisibility}}"
                              ItemTemplate="{StaticResource CaptureTargetTileTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding MonitorTiles}"
                              Visibility="{Binding IsScreensTabActive, Converter={StaticResource BoolToVisibility}}"
                              ItemTemplate="{StaticResource CaptureTargetTileTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Footer: Share + Cancel. -->
        <Border Grid.Row="3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Padding="20,12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Opacity="0.7" FontSize="11"
                           VerticalAlignment="Center" />
                <ui:Button Grid.Column="1"
                           Appearance="Secondary"
                           Content="Cancel"
                           Command="{Binding CancelCommand}"
                           Margin="0,0,8,0" />
                <ui:Button Grid.Column="2"
                           Appearance="Primary"
                           Content="Share"
                           Icon="{ui:SymbolIcon Symbol=Play24}"
                           Command="{Binding ShareCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
